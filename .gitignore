# Build artifacts
bin/
builds/
/zcp
*.test
RECIPE_RUNS/
docs/zcprecipator3/runs/

# Secrets
.env
.env.*
!.env.example
*.key
*.pem
.mcp.json

# Claude Code personal settings + generated files
CLAUDE.local.md
.claude/settings.local.json
.claude/compact-state.md
.claude/last-test-result
.claude/worktrees/
.claude/agent-memory/
.claude/teams/
.claude/tasks/
.claude/github-ci-token

# Workflow state (created by tests and runtime)
**/.zcp/

# Test-generated reflog (workflow engine appends to {cwd}/CLAUDE.md on bootstrap close)
integration/CLAUDE.md

# OS
.DS_Store
Thumbs.db

# Synced knowledge — generated by `zcp sync pull` (or `make sync`).
# Run `zcp sync pull` before build.
internal/knowledge/recipes/*.md
internal/knowledge/guides/*.md
internal/knowledge/decisions/*.md
# ZCP-internal agent protocols — not synced from upstream docs; tracked
# in this repo because they're consumed by atom cross-references.
!internal/knowledge/guides/verify-web-agent-protocol.md

# Go
tmp/
vendor/

# Eval results (logs, jsonl, extracted json)
eval/results/*
!eval/results/.gitkeep
eval-results/

# Local debug artifacts — raw session logs, workflow debug dumps
RAW_SESSION_LOG*
DEBUG_WORKFLOW*.json

# IDE
.idea/
.vscode/
*.swp
*~

# Autonomous-loop scheduling state (per-PID lock)
.claude/scheduled_tasks.lock
